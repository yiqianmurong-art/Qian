{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user-specific information and preferences.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "walletBalance": { "type": "number", "description": "Current balance in RM" },
        "createdAt": { "type": "string", "format": "date-time" },
        "preferences": {
          "type": "object",
          "properties": {
            "notifications": { "type": "boolean" },
            "darkMode": { "type": "boolean" },
            "language": { "type": "string" }
          }
        }
      },
      "required": ["displayName", "email", "role", "walletBalance"]
    },
    "Station": {
      "title": "Bike Station",
      "description": "Information about a bike sharing station.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "bikes": { "type": "integer" },
        "ebikes": { "type": "integer" },
        "slots": { "type": "integer" }
      },
      "required": ["name", "lat", "lng", "bikes", "ebikes", "slots"]
    },
    "Ride": {
      "title": "Ride Record",
      "description": "Details of a completed or active ride.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "bikeType": { "type": "string", "enum": ["standard", "electric"] },
        "fromStationId": { "type": "string" },
        "toStationId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "duration": { "type": "integer", "description": "Duration in seconds" },
        "distance": { "type": "number" },
        "cost": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "completed"] }
      },
      "required": ["userId", "bikeType", "fromStationId", "startTime", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "stations/{stationId}": {
      "schema": "Station",
      "description": "Global station information."
    },
    "users/{userId}/rides/{rideId}": {
      "schema": "Ride",
      "description": "User's ride history."
    }
  }
}
